# Copy to .env.production for production builds.
# Do not put secrets here — VITE_* values are embedded in the browser bundle.

# Same-origin reverse proxy (recommended): leave empty or omit this file.
# API and static assets are served from the same domain.
# VITE_API_BASE_URL=

# Separate API domain only (public URL, not a secret):
# VITE_API_BASE_URL=https://api.example.com
